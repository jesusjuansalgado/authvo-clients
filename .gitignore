# --- Generated by setup.sh / provisioning (do NOT commit) -------------------
# Local TLS material — includes PRIVATE KEYS. Regenerated by setup.sh.
test-integration/certs/
# Traefik dynamic TLS config — written by setup.sh.
test-integration/traefik/dynamic/
# JWT signing key set — contains a PRIVATE RSA key. Generated locally.
test-integration/iam/keys/
# The client_id written by seed.sh / DCR.
test-integration/seed/client_id

# --- Safety nets: never commit key material, whatever the path --------------
*.key
*.csr
*.srl
keystore.jwks

# --- Build / tooling junk ----------------------------------------------------
__pycache__/
*.pyc
target/
*.class
.DS_Store
