# INDIGO IAM container configuration (env var NAMES vary by release — check the
# configuration reference for the tag you pinned in docker-compose.yml).
#
# The issuer MUST match what the PRM sidecar advertises and what the resource
# server validates: https://iam.local.io/
IAM_HOST=iam.local.io
IAM_BASE_URL=https://iam.local.io
IAM_ISSUER=https://iam.local.io/
IAM_USE_FORWARDED_HEADERS=true
IAM_FORWARD_HEADERS_STRATEGY=native

# Put the granted scopes into the JWT access token (default is false) so the
# resource server can enforce vo.read from the token itself.
IAM_ACCESS_TOKEN_INCLUDE_SCOPE=true

IAM_JAVA_OPTS=-Dspring.profiles.active=mysql,registration -Djava.security.egd=file:/dev/./urandom

# Flyway bundles migrations for several DB vendors under db/migration/{h2,mysql,...};
# pin to the mysql set so it doesn't see two "V1" migrations and abort at boot.
SPRING_FLYWAY_LOCATIONS=classpath:db/migration/mysql

# Database (matches the db service).
# The IAM_DB_* names below aren't honored by v1.10.0 (it fell back to embedded
# H2 and tried to run the MySQL migrations against it). Drive the datasource
# with the standard Spring Boot properties instead so it connects to MariaDB.
IAM_DB_HOST=db
IAM_DB_PORT=3306
IAM_DB_NAME=iam
IAM_DB_USERNAME=iam
IAM_DB_PASSWORD=pwd
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/iam
SPRING_DATASOURCE_USERNAME=iam
SPRING_DATASOURCE_PASSWORD=pwd
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# A signing keystore is required so access tokens are JWTs the RS can verify.
# v1.10.0 ships no default keystore; we generate a JWK set (kid=rsa1) and mount
# it at /keystore.jwks (see docker-compose.yml). default-key-id defaults to rsa1.
IAM_KEY_STORE_LOCATION=file:/keystore.jwks

# Enable the grants the AuthVO flow needs:
#   - device code (RFC 8628), dynamic client registration (RFC 7591)
#   - token exchange (RFC 8693)  <- INDIGO supports this
# These are typically enabled per-client at registration time (see seed.sh),
# not globally, on current INDIGO releases.
